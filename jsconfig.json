{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "main/*": ["src/main/*"],
      "infra/*": ["src/main/infra/*"],
      "models/*": ["src/main/models/*"],
      "validators/*": ["src/main/validators/*"],
      "services/*": ["src/main/services/*"],
      "handlers/*": ["src/main/handlers/*"],
